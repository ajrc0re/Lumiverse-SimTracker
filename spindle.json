{
  "version": "1.3.7",
  "name": "Silly Sim Tracker",
  "identifier": "silly_sim_tracker",
  "author": "c0re fork",
  "github": "https://github.com/ajrc0re/Lumiverse-SimTracker",
  "homepage": "https://github.com/ajrc0re/Lumiverse-SimTracker",
  "description": "Lumiverse port in progress for rendering tracker cards from sim code blocks.",
  "permissions": [
    "interceptor",
    "ephemeral_storage",
    "chat_mutation",
    "chats",
    "event_tracking",
    "generation",
    "generation_parameters",
    "app_manipulation"
  ],
  "entry_backend": "dist/backend.js",
  "entry_frontend": "dist/frontend.js",
  "storage_seed_files": [
    {
      "from": "tracker-card-templates",
      "to": "templates",
      "overwrite": true,
      "required": true
    },
    {
      "from": "custom",
      "to": "templates",
      "overwrite": true,
      "required": true
    }
  ],
  "minimum_lumiverse_version": "1.0.1"
}
